<div id="<%= dom_id(advisory) %>" class="rounded-xl border border-brand-100 bg-white p-4 shadow-sm">
  <div class="flex items-center justify-between">
    <span class="text-xs font-bold uppercase tracking-wide text-advisory-500">Live advisory</span>
    <span class="text-xs text-muted">order #<%= advisory.order.queue_number %></span>
  </div>
  <p class="mt-1 font-semibold text-ink"><%= advisory.text %></p>
  <% if advisory.rationale.present? %>
    <p class="mt-0.5 text-sm text-muted"><%= advisory.rationale %></p>
  <% end %>

  <% if advisory.pending? %>
    <div class="mt-3 flex gap-2">
      <%= button_to "Accept", accept_advisory_path(advisory), method: :patch,
            class: "rounded-lg bg-accept-600 px-4 py-1.5 text-sm font-semibold text-white hover:bg-accept-500" %>
      <%= button_to "Override", override_advisory_path(advisory), method: :patch,
            class: "rounded-lg border border-muted px-4 py-1.5 text-sm font-semibold text-muted hover:bg-surface" %>
    </div>
  <% else %>
    <p class="mt-2 text-xs font-bold uppercase <%= advisory.accepted? ? 'text-accept-600' : 'text-muted' %>">
      <%= advisory.status %>
    </p>
  <% end %>
</div>
