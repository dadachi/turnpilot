<%
  kind_label = {
    "walk_away_risk" => "Delay risk",
    "open_server"    => "Capacity",
    "queue_building" => "Queue building",
    "walked_away"    => "Walk-off"
  }[advisory.kind] || "Advisory"
  subject = advisory.order ? "order ##{advisory.order.queue_number}" : "whole kitchen"
  # Scope cue so a per-order advisory (🧾) is instantly distinct from a shop-wide one (🍳).
  scope_icon = advisory.order ? "🧾" : "🍳"
%>
<% if advisory.pending? %>
  <%# Live, actionable advisory. Every pending card looks the same — pink left-accent = "act
      now". Category label + subject so cards read distinctly; newest is already obvious (on top). %>
  <div id="<%= dom_id(advisory) %>"
       class="rounded-xl border border-brand-100 border-l-4 border-l-advisory-500 bg-white p-4 shadow-sm">
    <div class="flex items-center justify-between">
      <span class="text-xs font-bold uppercase tracking-wide text-advisory-500"><%= kind_label %></span>
      <span class="inline-flex items-center gap-1 rounded-full bg-surface px-2 py-0.5 text-xs font-semibold text-muted">
        <span aria-hidden="true"><%= scope_icon %></span> <%= subject %>
      </span>
    </div>
    <p class="mt-1 font-semibold text-ink"><%= advisory.text %></p>
    <% if advisory.rationale.present? %>
      <p class="mt-0.5 text-sm text-muted"><%= advisory.rationale %></p>
    <% end %>

    <div class="mt-3 flex gap-2">
      <%= button_to "Accept", accept_advisory_path(advisory), method: :patch,
            class: "rounded-lg bg-accept-600 px-4 py-1.5 text-sm font-semibold text-white hover:bg-accept-500" %>
      <%= button_to "Dismiss", override_advisory_path(advisory), method: :patch,
            title: "Dismiss — tells TurnPilot this wasn't worth alerting on, so it alerts less next time",
            class: "rounded-lg border border-muted px-4 py-1.5 text-sm font-semibold text-muted hover:bg-surface" %>
    </div>

    <p class="mt-3 flex items-center gap-1.5 text-[11px] font-medium text-muted"
       title="Generated by Gemma 4 running locally via Ollama — no network, no cloud">
      <span class="h-1.5 w-1.5 rounded-full bg-accept-500"></span>
      Reasoned locally by Gemma 4 · 0 cloud calls
    </p>
  </div>
<% else %>
  <%# Handled (accepted / overridden) or auto-resolved (order finished cooking) — collapse to a
      one-line row so the loop visibly closes and the screen declutters. %>
  <%
    icon  = advisory.overridden? ? "↩" : "✓"
    tone  = advisory.accepted? ? "text-accept-600" : "text-muted"
    label = advisory.resolved? ? "cleared · order done" : (advisory.overridden? ? "dismissed" : advisory.status)
  %>
  <div id="<%= dom_id(advisory) %>"
       class="flex items-center gap-2 rounded-lg border border-surface bg-surface px-3 py-2 text-sm">
    <span class="shrink-0 <%= tone %>"><%= icon %></span>
    <span class="shrink-0 text-xs font-semibold uppercase text-muted"><span aria-hidden="true"><%= scope_icon %></span> <%= subject %></span>
    <span class="truncate text-muted"><%= advisory.text %></span>
    <span class="ml-auto shrink-0 text-xs font-semibold uppercase <%= tone %>"><%= label %></span>
  </div>
<% end %>
