<%= turbo_stream_from "console" %>
<div class="mx-auto max-w-2xl p-6">
  <header class="mb-4 flex items-center justify-between">
    <h1 class="text-xl font-bold text-ink">
      TurnPilot <span class="text-brand-500">·</span> Cafe demo
    </h1>
    <%= button_to "Run rush", console_demo_path, method: :post,
          class: "rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-500" %>
  </header>

  <p class="mb-4 text-sm text-muted">
    <%= Order.open.count %> orders open ·
    <span class="font-semibold text-advisory-500"><%= Order.open.select(&:flagged?).count %> flagged</span>
    · reasoning on Gemma 4, on-device
  </p>

  <div id="advisories" class="space-y-3">
    <%= render Advisory.recent.limit(20) %>
  </div>
</div>
