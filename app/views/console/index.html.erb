<%= turbo_stream_from "console" %>
<div class="mx-auto w-full min-w-0 max-w-2xl p-6"
     data-controller="replay voice"
     data-replay-url-value="<%= console_tick_path %>"
     data-replay-interval-value="4000">
  <header class="mb-3">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <h1 class="text-xl font-bold text-ink">TurnPilot</h1>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-accept-500 px-2.5 py-0.5 text-xs font-semibold text-accept-600"
                title="All reasoning runs on this device via Ollama — no network, no cloud">
            <span class="h-1.5 w-1.5 rounded-full bg-accept-500"></span> Offline · Gemma 4 on-device
          </span>
        </div>
        <p class="mt-1 text-sm text-muted">Spots late orders and tells staff what to do — reasoning on-device, offline.</p>
      </div>
      <div class="flex items-center gap-2"
           data-controller="camera" data-camera-url-value="<%= vision_observations_path %>">
        <span data-camera-target="indicator" style="display:none"
              class="inline-flex items-center gap-1.5 text-xs font-semibold text-advisory-500">
          <span class="h-2 w-2 rounded-full bg-advisory-500 animate-pulse"></span> camera on
        </span>
        <button type="button" data-camera-target="button" data-action="camera#toggle"
                class="rounded-lg border border-muted px-3 py-2 text-sm font-semibold text-muted hover:bg-surface">
          Camera
        </button>
        <button type="button" data-voice-target="button" data-action="voice#toggle"
                title="Speak each new advisory aloud (offline browser voice)"
                class="rounded-lg border border-muted px-3 py-2 text-sm font-semibold text-muted hover:bg-surface">
          Read aloud
        </button>
      </div>
    </div>
  </header>

  <div class="mb-4 rounded-lg border border-dashed border-brand-100 bg-brand-50/40 px-3 py-2">
    <div class="flex flex-wrap items-center gap-2 text-xs text-muted">
      <span class="font-semibold uppercase tracking-wide">Demo controls</span>
      <span class="rounded-full bg-white px-2 py-0.5 font-semibold text-brand-700 shadow-sm">Live replay · Cafe</span>
      <%= button_to "Run rush", console_demo_path, method: :post,
            class: "rounded-md bg-brand-600 px-3 py-1 font-semibold text-white hover:bg-brand-500" %>
      <span class="ml-1 font-semibold">Simulate camera:</span>
      <% { "waiting" => "customer waiting", "busy" => "line forming", "left" => "customer left" }.each do |scenario, label| %>
        <%= button_to label, vision_simulate_path(scenario: scenario), method: :post,
              class: "rounded-md border border-brand-100 bg-white px-2.5 py-1 font-semibold text-brand-700 hover:bg-brand-100" %>
      <% end %>
    </div>
  </div>

  <%= render "status" %>

  <h2 class="mb-1 mt-4 text-xs font-semibold uppercase tracking-wide text-muted">Live queue</h2>
  <%= render "queue" %>

  <h2 class="mb-2 mt-4 text-xs font-semibold uppercase tracking-wide text-muted">What TurnPilot advises</h2>
  <div id="advisories" class="space-y-3" data-controller="chime">
    <%= render Advisory.recent.limit(20) %>
  </div>

  <div id="toast" class="pointer-events-none fixed inset-x-0 bottom-6 z-50 flex flex-col items-center"></div>
</div>
